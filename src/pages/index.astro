---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>woosdom — 4-engine AI orchestration journal</title>
    <meta name="description" content="한 명의 건축가가 4개의 AI 엔진으로 설계·구현·검증·감사까지 수행한 기록." />
    <style>
      body { max-width: 720px; margin: 2rem auto; padding: 0 1rem; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; line-height: 1.6; color: #222; }
      header { margin-bottom: 2rem; }
      h1 { margin: 0 0 0.5rem; font-size: 1.8rem; }
      .tagline { color: #666; }
      .cta { margin: 1.5rem 0; padding: 1rem; background: #f6f8fa; border-left: 4px solid #2563eb; }
      ul.posts { list-style: none; padding: 0; }
      ul.posts li { padding: 1rem 0; border-bottom: 1px solid #eee; }
      a { color: #2563eb; text-decoration: none; }
      a:hover { text-decoration: underline; }
      time { color: #888; font-size: 0.85rem; }
      h2 { margin: 0.2rem 0; font-size: 1.1rem; }
      p.desc { color: #555; margin: 0.3rem 0; }
    </style>
  </head>
  <body>
    <header>
      <h1>🧠 woosdom</h1>
      <p class="tagline">4-engine AI orchestration — 한 명의 건축가가 Claude / GPT / Gemini / Antigravity로 SaaS를 배포한 기록</p>
      <div class="cta">
        생성자 ≠ 검증자. 3-Stage Gate. Fail-Driven. —
        <a href="https://github.com/ahnsemble/woosdom">GitHub</a>에서 redact된 공개 스냅샷을 확인하세요.
      </div>
    </header>
    <main>
      <h2>Posts</h2>
      <ul class="posts">
        {posts.map((p) => (
          <li>
            <time datetime={p.data.pubDate.toISOString().slice(0,10)}>
              {p.data.pubDate.toISOString().slice(0,10)}
            </time>
            <h2><a href={`/blog/${p.data.slug ?? p.id}`}>{p.data.title}</a></h2>
            <p class="desc">{p.data.description}</p>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
